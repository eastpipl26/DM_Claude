{
  "permissions": {
    "allow": [
      "PowerShell(Get-Item \\(Get-Command python.exe\\).Source)",
      "Bash(*)",
      "PowerShell(*)",
      "Read(*)",
      "Write(*)",
      "Edit(*)",
      "Glob(*)",
      "Grep(*)",
      "WebFetch(*)",
      "WebSearch(*)",
      "TodoWrite(*)",
      "mcp__claude_ai_Google_Drive__*"
    ],
    "defaultMode": "acceptEdits"
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "C:\\Users\\eastp\\AppData\\Local\\Programs\\Python\\Python312\\python.exe \"C:\\Users\\eastp\\.claude\\scripts\\memory_break_check.py\"",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "C:\\Users\\eastp\\AppData\\Local\\Programs\\Python\\Python312\\python.exe \"C:\\Users\\eastp\\.claude\\scripts\\hook_update.py\"",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "C:\\Users\\eastp\\AppData\\Local\\Programs\\Python\\Python312\\python.exe \"C:\\Users\\eastp\\.claude\\scripts\\delegation_gate.py\"",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "C:\\Users\\eastp\\AppData\\Local\\Programs\\Python\\Python312\\python.exe \"C:\\Users\\eastp\\.claude\\scripts\\hook_update.py\"",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"C:\\\\Users\\\\eastp\\\\.claude\\\\scripts\\\\gptaku-update-check.cjs\"",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "insane-search@gptaku-plugins": true,
    "telegram@claude-plugins-official": true,
    "caveman@caveman": true
  },
  "extraKnownMarketplaces": {
    "gptaku-plugins": {
      "source": {
        "source": "git",
        "url": "https://github.com/fivetaku/gptaku_plugins.git"
      }
    },
    "claude-plugins-official": {
      "source": {
        "source": "github",
        "repo": "anthropics/claude-plugins-official"
      }
    },
    "caveman": {
      "source": {
        "source": "github",
        "repo": "JuliusBrussee/caveman"
      }
    }
  },
  "skipDangerousModePermissionPrompt": true,
  "theme": "dark",
  "inputNeededNotifEnabled": true,
  "agentPushNotifEnabled": true
}
